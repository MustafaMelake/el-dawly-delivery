// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum OrderStatus {
  PENDING
  ASSIGNED
  DELIVERED
  CANCELLED
}

enum CourierStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum Zone {
  MENOUF
  SERS
  BERHEEM
}

model Courier {
  id     String        @id @default(cuid())
  name   String
  phone  String        @unique
  status CourierStatus @default(OFFLINE)

  // Order of Courier
  lastAvailableAt DateTime @default(now())

  // Courier percentage
  commissionRate Float? @default(0)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, lastAvailableAt])
}

model Order {
  id String @id @default(cuid())

  // client Data
  clientName  String
  clientPhone String

  // order details 
  description    String @db.Text
  pickupAddress  String @db.Text
  dropoffAddress String @db.Text
  fromZone       Zone   @default(MENOUF)
  toZone         Zone

  // 💡 Financial Part
  deliveryFee    Float
  itemCost       Float @default(0)
  totalCollected Float @default(0)

  status OrderStatus @default(PENDING)

  // Link order with Delivery
  courierId String?
  courier   Courier? @relation(fields: [courierId], references: [id])

  // Order time rate
  assignedAt  DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([createdAt])
  @@index([status])
}

// =======================
// Better Auth Models
// =======================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean
  phone         String?  @unique 
  image         String?
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  orders Order[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
